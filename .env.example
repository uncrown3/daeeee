AUTH_SECRET=replace-with-a-long-random-string

# Add allowed users here. Example below contains two test users you can use:
# - alice@example.com / Pass123!
# - bob@example.com / Pass123!
# Paste the entire value as a single line (JSON array).
APP_USERS_JSON=[{"email":"alice@example.com","name":"Alice","password":"Pass123!"},{"email":"bob@example.com","name":"Bob","password":"Pass123!"}]

# Required for @vercel/blob uploads
BLOB_READ_WRITE_TOKEN=

# Optional: used to protect the cleanup endpoint from non-cron calls
CRON_SECRET=
